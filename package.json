{
  "name": "plataforma-biblica",
  "version": "1.0.0",
  "description": "Plataforma Bíblica Gamificada",
  "scripts": {
    "build": "npx tailwindcss -i ./src/css/input.css -o ./public/dist/output.css",
    "watch": "npx tailwindcss -i ./src/css/input.css -o ./public/dist/output.css --watch",
    "start": "npx live-server --port=3000"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "live-server": "^1.2.0"
  }
}
